# Variables de entorno para Expo
# Copiar este archivo a .env y completar valores

# ========================================
# API Backend
# ========================================
# IMPORTANTE: Cambiar IP por la de tu computadora en la red local
# Para obtenerla:
# - Windows: ipconfig (busca IPv4)
# - Mac/Linux: ifconfig (busca inet)
# NO usar localhost ni 127.0.0.1 (no funciona en móvil)
EXPO_PUBLIC_API_URL=http://192.168.1.XXX:3001/api

# ========================================
# Configuración General
# ========================================
EXPO_PUBLIC_ENV=development
EXPO_PUBLIC_TENANT_ID=default

# ========================================
# NOTAS
# ========================================
# - Expo usa EXPO_PUBLIC_* (no process.env)
# - Acceso: process.env.EXPO_PUBLIC_API_URL
# - Backend debe estar corriendo en misma red WiFi
# - Para probar en dispositivo físico, necesitas la IP real
