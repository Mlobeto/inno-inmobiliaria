    {
      "_id": "req_register_platform_admin",
      "_type": "request",
      "parentId": "folder_auth",
      "name": "Registrar Platform Admin",
      "method": "POST",
      "url": "{{ _.base_url }}/api/auth/register-platform-admin",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"username\": \"platform_admin\",\n  \"password\": \"Admin123\",\n  \"fullName\": \"Platform Administrator\",\n  \"email\": \"admin@innoinmo.com\"\n}"
      },
      "headers": [
        {
          "name": "Content-Type",
          "value": "application/json"
        }
      ],
      "description": "Crea un nuevo Platform Admin sin tenantId. Este usuario puede acceder al dashboard de administración de plataforma."
    },
    {
      "_id": "req_login",
      "_type": "request",
      "parentId": "folder_auth",
      "name": "Login Platform Admin",
      "method": "POST",
      "url": "{{ _.base_url }}/api/auth/login",
      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"username\": \"platform_admin\",\n  \"password\": \"Admin123\"\n}"
      },
      "headers": [
        {
          "name": "Content-Type",
          "value": "application/json"
        }
      ],
      "description": "Login como Platform Admin. Copia el token de la respuesta y pégalo en el Environment (token variable)."
