{
  "compilerOptions": {
    "checkJs": false,
    "module": "commonjs",
    "target": "ES2020",
    "moduleResolution": "node",
    "types": ["node"],
    "skipLibCheck": true
  },
  "include": [
    "src/**/*",
    "scripts/**/*",
    "index.js",
    "*.js",
    "node_modules/@types/node/index.d.ts"
  ],
  "exclude": ["prisma"]
}
