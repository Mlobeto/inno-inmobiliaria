# App
NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/innoinmo

# Redis
REDIS_URL=redis://localhost:6379

# Rate limit: login / register / forgot-password (intentos fallidos por IP por ventana)
# AUTH_RATE_LIMIT_MAX=5
# AUTH_RATE_LIMIT_WINDOW_MINUTES=15

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# MercadoPago
MP_ACCESS_TOKEN=your-mercadopago-access-token

# MercadoLibre OAuth
ML_CLIENT_ID=your-ml-client-id
ML_CLIENT_SECRET=your-ml-client-secret
ML_REDIRECT_URI=http://localhost:3001/api/integrations/mercadolibre/callback

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-email-password

# Encryption (32 bytes hex para AES-256)
ENCRYPTION_KEY=generate-this-with-crypto-randomBytes-32-toString-hex

# Logging
LOG_LEVEL=debug

# Elasticsearch (opcional, solo producción)
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_USER=elastic
ELASTICSEARCH_PASSWORD=your-password
