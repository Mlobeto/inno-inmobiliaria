generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model ClientProperties {
  role       enum_ClientProperties_role
  clientId   Int
  propertyId Int
  createdAt  DateTime                   @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime                   @default(now()) @updatedAt @db.Timestamptz(6)
  tenantId   Int
  Clients    Clients                    @relation(fields: [clientId], references: [idClient], onDelete: Cascade)
  Property   Property                   @relation(fields: [propertyId], references: [propertyId], onDelete: Cascade)
  tenants    tenants                    @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade, onUpdate: NoAction)

  @@id([clientId, propertyId])
  @@index([tenantId], map: "idx_client_properties_tenant")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model Clients {
  idClient                                      Int                @id @default(autoincrement())
  cuil                                          String?            @unique @db.VarChar(255)
  name                                          String             @db.VarChar(255)
  email                                         String?            @unique @db.VarChar(255)
  direccion                                     String?            @db.VarChar(255)
  ciudad                                        String             @db.VarChar(255)
  provincia                                     String?            @db.VarChar(255)
  mobilePhone                                   String             @db.VarChar(255)
  linkMaps                                      String?            @db.VarChar(255)
  createdAt                                     DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt                                     DateTime           @default(now()) @updatedAt @db.Timestamptz(6)
  deletedAt                                     DateTime?          @db.Timestamptz(6)
  tenantId                                      Int
  migrated_to_documents                         Boolean?           @default(false)
  codigo_postal                                 String?            @db.VarChar(10)
  ClientProperties                              ClientProperties[]
  tenants                                       tenants            @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade, onUpdate: NoAction)
  Leases_Leases_landlordIdToClients             Leases[]           @relation("Leases_landlordIdToClients")
  Leases_Leases_renterIdToClients               Leases[]           @relation("Leases_renterIdToClients")
  PaymentReceipts                               PaymentReceipts[]
  SaleContracts_SaleContracts_buyerIdToClients  SaleContracts[]    @relation("SaleContracts_buyerIdToClients")
  SaleContracts_SaleContracts_sellerIdToClients SaleContracts[]    @relation("SaleContracts_sellerIdToClients")
  client_documents                              client_documents[]
  commissions                                   commissions[]

  @@index([codigo_postal], map: "idx_clients_codigo_postal")
  @@index([migrated_to_documents], map: "idx_clients_migration_status", where: raw("(migrated_to_documents = false)"))
  @@index([tenantId], map: "idx_clients_tenant")
}

model Garantors {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(255)
  cuil        String   @db.VarChar(255)
  address     String   @db.VarChar(255)
  mobilePhone String?  @db.VarChar(255)
  email       String?  @unique @db.VarChar(255)
  description String   @db.VarChar(255)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  leaseId     Int?
  tenantId    Int?
  tenants     tenants? @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade, onUpdate: NoAction)

  @@index([tenantId], map: "idx_garantors_tenant")
}

model Leases {
  id                                 Int       @id @default(autoincrement())
  tenantId                           Int
  propertyId                         Int
  landlordId                         Int
  renterId                           Int
  agentId                            Int?
  startDate                          DateTime  @db.Date
  rentAmount                         Decimal   @db.Decimal(12, 2)
  updateFrequency                    String?   @db.VarChar(50)
  commission                         Decimal?  @db.Decimal(5, 2)
  totalMonths                        Int
  inventory                          String
  garantiaType                       String?   @db.VarChar(20)
  seguroCaucionCompania              String?   @db.VarChar(255)
  seguroCaucionDatos                 String?
  status                             String?   @default("active") @db.VarChar(50)
  pdfPath                            String?   @db.VarChar(500)
  customContent                      String?
  createdAt                          DateTime? @default(now()) @db.Timestamp(6)
  updatedAt                          DateTime? @default(now()) @db.Timestamp(6)
  deletedAt                          DateTime? @db.Timestamp(6)
  admins                             admins?   @relation(fields: [agentId], references: [adminId], onUpdate: NoAction)
  Clients_Leases_landlordIdToClients Clients   @relation("Leases_landlordIdToClients", fields: [landlordId], references: [idClient], onUpdate: NoAction)
  Property                           Property  @relation(fields: [propertyId], references: [propertyId], onUpdate: NoAction)
  Clients_Leases_renterIdToClients   Clients   @relation("Leases_renterIdToClients", fields: [renterId], references: [idClient], onUpdate: NoAction)
  tenants                            tenants   @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade, onUpdate: NoAction)

  @@index([agentId], map: "idx_leases_agent")
  @@index([landlordId], map: "idx_leases_landlord")
  @@index([propertyId], map: "idx_leases_property")
  @@index([renterId], map: "idx_leases_renter")
  @@index([status], map: "idx_leases_status")
  @@index([tenantId], map: "idx_leases_tenant")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model MercadoLibreConfig {
  id             Int       @id @default(autoincrement())
  tenantId       Int       @unique
  mlUserId       String?   @db.VarChar(100)
  accessToken    String?
  accessTokenIv  String?   @db.VarChar(32)
  accessTokenAuthTag String? @db.VarChar(32)
  accessTokenSalt String?  @db.VarChar(128)
  refreshToken   String?
  refreshTokenIv String?   @db.VarChar(32)
  refreshTokenAuthTag String? @db.VarChar(32)
  refreshTokenSalt String? @db.VarChar(128)
  tokenExpiresAt DateTime? @db.Timestamp(6)
  isActive       Boolean?  @default(false)
  lastSync       DateTime? @db.Timestamp(6)
  createdAt      DateTime  @default(now()) @db.Timestamp(6)
  updatedAt      DateTime  @default(now()) @db.Timestamp(6)
  tenants        tenants   @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade, onUpdate: NoAction)

  @@index([isActive], map: "idx_ml_config_active")
  @@index([tenantId], map: "idx_ml_config_tenant")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model MercadoLibreMessages {
  id           Int       @id @default(autoincrement())
  tenantId     Int
  propertyId   Int?
  mlListingId  String?   @db.VarChar(100)
  mlMessageId  String    @unique @db.VarChar(100)
  mlQuestionId String?   @db.VarChar(100)
  mlUserId     String?   @db.VarChar(100)
  userNickname String?   @db.VarChar(255)
  message      String
  answer       String?
  status       String?   @default("UNANSWERED") @db.VarChar(50)
  isRead       Boolean?  @default(false)
  receivedAt   DateTime? @db.Timestamp(6)
  answeredAt   DateTime? @db.Timestamp(6)
  createdAt    DateTime  @default(now()) @db.Timestamp(6)
  updatedAt    DateTime  @default(now()) @db.Timestamp(6)
  Property     Property? @relation(fields: [propertyId], references: [propertyId], onUpdate: NoAction)
  tenants      tenants   @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade, onUpdate: NoAction)

  @@index([propertyId], map: "idx_ml_msg_property")
  @@index([isRead], map: "idx_ml_msg_read")
  @@index([receivedAt], map: "idx_ml_msg_received")
  @@index([status], map: "idx_ml_msg_status")
  @@index([tenantId], map: "idx_ml_msg_tenant")
}

model PaymentReceipts {
  id                Int                         @id @default(autoincrement())
  paymentDate       DateTime                    @db.Timestamptz(6)
  amount            Decimal                     @db.Decimal           // Siempre en ARS
  originalAmount    Decimal?                    @db.Decimal           // Monto en moneda original (ej: USD)
  originalCurrency  String?                     @default("ARS") @db.VarChar(3)
  dolarRateUsed     Decimal?                    @db.Decimal           // Cotización usada al registrar
  period            String                      @db.VarChar(255)
  installmentNumber Int?
  totalInstallments Int?
  type              enum_PaymentReceipts_type          @default(installment)
  status            enum_PaymentReceipts_status         @default(pending)
  voucherUrl        String?                             @db.VarChar(1000)         // URL comprobante en Azure Blob
  voucherStatus     enum_PaymentReceipts_voucherStatus  @default(none)            // Estado del comprobante subido por inquilino
  voucherRejReason  String?                             @db.VarChar(500)          // Motivo de rechazo (si aplica)
  paidAt            DateTime?                           @db.Timestamptz(6)        // Fecha en que se marcó como pagado
  createdAt         DateTime                            @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime                            @default(now()) @updatedAt @db.Timestamptz(6)
  deletedAt         DateTime?                           @db.Timestamptz(6)
  leaseId           Int?
  idClient          Int?
  tenantId          Int?
  Clients           Clients?                    @relation(fields: [idClient], references: [idClient])
  tenants           tenants?                    @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade, onUpdate: NoAction)

  @@index([tenantId], map: "idx_payment_receipts_tenant")
  @@index([originalCurrency], map: "idx_payment_receipts_currency")
}

model Property {
  propertyId           Int                        @id @default(autoincrement())
  address              String                     @db.VarChar(255)
  neighborhood         String?                    @db.VarChar(255)
  socio                String?                    @db.VarChar(255)
  city                 String?                    @db.VarChar(255)
  type                 enum_Property_type
  typeProperty         enum_Property_typeProperty
  price                Decimal                    @db.Decimal
  precioReferencia     Decimal?                   @db.Decimal
  rooms                Int?
  comision             Decimal                    @db.Decimal
  isAvailable          Boolean?                   @default(true)
  description          String?
  legalStatus          enum_Property_legalStatus  @map("escritura")
  matriculaOPadron     String?                    @db.VarChar(255)
  frente               String?                    @db.VarChar(255)
  profundidad          String?                    @db.VarChar(255)
  linkInstagram        String?                    @db.VarChar(255)
  linkMaps             String?                    @db.VarChar(255)
  images               String[]                   @default([]) @db.VarChar(255)
  plantType            String?                    @db.VarChar(255)
  plantQuantity        Int?
  bathrooms            Int?
  highlights           String?
  inventory            String?
  superficieCubierta   String?                    @db.VarChar(255)
  superficieTotal      String?                    @db.VarChar(255)
  requisito            String?
  whatsappTemplate     String?                    @default("Gracias por ponerte en contacto con Quintero Lobeto Propiedades! Estamos encantados de poder ayudar. \n\n{descripcion}\n\nTe comento que estamos en lanzamiento de ofertas y este es el primero!\n\nPrecio: AR$ {precio}\nUbicación: {direccion}\n\nEstamos a tu entera disposición por dudas, precio o consultas.")
  createdAt            DateTime                   @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime                   @default(now()) @updatedAt @db.Timestamptz(6)
  deletedAt            DateTime?                  @db.Timestamptz(6)
  tenantId             Int
  agentId              Int?
  rentalType           String?                    @default("TRADICIONAL") @db.VarChar(50)
  minStayDays          Int?
  currency             String                     @default("ARS") @db.VarChar(3)
  isPublishedInLanding Boolean?                   @default(false)
  rentedAt             DateTime?                  @db.Timestamp(6)
  ClientProperties     ClientProperties[]
  Leases               Leases[]
  MercadoLibreMessages MercadoLibreMessages[]
  admins               admins?                    @relation(fields: [agentId], references: [adminId], onUpdate: NoAction)
  tenants              tenants                    @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade, onUpdate: NoAction)
  PropertyMLListings   PropertyMLListings[]
  SaleContracts        SaleContracts[]
  commissions          commissions[]

  @@index([agentId], map: "idx_property_agent")
  @@index([tenantId], map: "idx_property_tenant")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model PropertyMLListings {
  id          Int       @id @default(autoincrement())
  propertyId  Int
  tenantId    Int
  mlListingId String    @db.VarChar(100)
  mlStatus    String?   @db.VarChar(50)
  mlPermalink String?
  mlTitle     String?   @db.VarChar(255)
  mlPrice     Decimal?  @db.Decimal(15, 2)
  viewsCount  Int?      @default(0)
  lastSync    DateTime? @db.Timestamp(6)
  syncErrors  String?
  createdAt   DateTime  @default(now()) @db.Timestamp(6)
  updatedAt   DateTime  @default(now()) @db.Timestamp(6)
  Property    Property  @relation(fields: [propertyId], references: [propertyId], onDelete: Cascade, onUpdate: NoAction)
  tenants     tenants   @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade, onUpdate: NoAction)

  @@unique([propertyId, tenantId])
  @@index([mlListingId], map: "idx_ml_listing_id")
  @@index([propertyId], map: "idx_ml_listing_property")
  @@index([mlStatus], map: "idx_ml_listing_status")
  @@index([tenantId], map: "idx_ml_listing_tenant")
}

model RentUpdates {
  id            Int       @id @default(autoincrement())
  updateDate    DateTime  @db.Timestamptz(6)
  oldRentAmount Decimal   @db.Decimal
  newRentAmount Decimal   @db.Decimal
  period        String    @db.VarChar(255)
  pdfPath       String?   @db.VarChar(255)
  createdAt     DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  deletedAt     DateTime? @db.Timestamptz(6)
  leaseId       Int?
  tenantId      Int?
  tenants       tenants?  @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade, onUpdate: NoAction)

  @@index([tenantId], map: "idx_rent_updates_tenant")
}

model SaleContracts {
  id                                      Int      @id @default(autoincrement())
  saleDate                                DateTime @db.Timestamptz(6)
  salePrice                               Decimal  @db.Decimal
  commission                              Decimal? @db.Decimal
  propertyId                              Int
  sellerId                                Int
  buyerId                                 Int
  createdAt                               DateTime @default(now()) @db.Timestamptz(6)
  updatedAt                               DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  tenantId                                Int?
  agentId                                 Int?
  admins                                  admins?  @relation(fields: [agentId], references: [adminId], onUpdate: NoAction)
  Clients_SaleContracts_buyerIdToClients  Clients  @relation("SaleContracts_buyerIdToClients", fields: [buyerId], references: [idClient], onDelete: NoAction)
  Property                                Property @relation(fields: [propertyId], references: [propertyId], onDelete: NoAction)
  Clients_SaleContracts_sellerIdToClients Clients  @relation("SaleContracts_sellerIdToClients", fields: [sellerId], references: [idClient], onDelete: NoAction)
  tenants                                 tenants? @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade, onUpdate: NoAction)

  @@index([agentId], map: "idx_sale_contracts_agent")
  @@index([tenantId], map: "idx_sale_contracts_tenant")
}

