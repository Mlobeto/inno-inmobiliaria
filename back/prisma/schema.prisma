  company_name             String?  @db.VarChar(255)
  company_address          String?  @db.VarChar(255)
  company_phone            String?  @db.VarChar(255)
  company_email            String?  @db.VarChar(255)
  company_registration     String?  @db.VarChar(255)
  company_cuit             String?  @db.VarChar(255)
  company_logo_url         String?  @db.VarChar(255)
