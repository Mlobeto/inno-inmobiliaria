model commissions {
  id                                    Int       @id @default(autoincrement())
  tenantId                              Int
  agentId                               Int
  transactionType                       String    @db.VarChar(50)
  transactionId                         Int
  propertyId                            Int
  clientId                              Int?
  transactionAmount                     Decimal   @db.Decimal(12, 2)
  inmobiliariaCommissionPercent         Decimal?  @db.Decimal(5, 2)
  inmobiliariaCommissionAmount          Decimal?  @db.Decimal(12, 2)
  agentCommissionPercent                Decimal?  @db.Decimal(5, 2)
  agentCommissionAmount                 Decimal?  @db.Decimal(12, 2)
  status                                String?   @default("PENDING") @db.VarChar(50)
  approvedBy                            Int?
  approvedAt                            DateTime? @db.Timestamp(6)
  paidAt                                DateTime? @db.Timestamp(6)
  notes                                 String?
  createdAt                             DateTime? @default(now()) @db.Timestamp(6)
  updatedAt                             DateTime? @default(now()) @db.Timestamp(6)
  admins_commissions_agentIdToadmins    admins    @relation("commissions_agentIdToadmins", fields: [agentId], references: [adminId], onUpdate: NoAction)
  admins_commissions_approvedByToadmins admins?   @relation("commissions_approvedByToadmins", fields: [approvedBy], references: [adminId], onUpdate: NoAction)
  Clients                               Clients?  @relation(fields: [clientId], references: [idClient], onUpdate: NoAction)
  Property                              Property  @relation(fields: [propertyId], references: [propertyId], onUpdate: NoAction)
  tenants                               tenants   @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade, onUpdate: NoAction)

  @@index([agentId], map: "idx_commissions_agent")
  @@index([status], map: "idx_commissions_status")
  @@index([tenantId], map: "idx_commissions_tenant")
  @@index([transactionType], map: "idx_commissions_type")
}

model garantors {
  garantorId   Int      @id @default(autoincrement())
  leaseId      Int?
  name         String   @db.VarChar(255)
  dni          String?  @db.VarChar(20)
  phone        String?  @db.VarChar(50)
  address      String?
  email        String?  @db.VarChar(255)
  relationship String?  @db.VarChar(100)
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
