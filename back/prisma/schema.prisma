  @@index([tenant_id], map: "idx_admin_settings_tenant")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model admins {
  adminId                                    Int                     @id @default(autoincrement())
  username                                   String                  @unique @db.VarChar(255)
  password                                   String                  @db.VarChar(255)
  role                                       String?                 @default("admin") @db.VarChar(50)
  createdAt                                  DateTime                @default(now()) @db.Timestamptz(6)
  updatedAt                                  DateTime                @default(now()) @db.Timestamptz(6)
  deletedAt                                  DateTime?               @db.Timestamptz(6)
  tenantId                                   Int?
  fullName                                   String?                 @db.VarChar(255)
  email                                      String?                 @db.VarChar(255)
  Leases                                     Leases[]
  Property                                   Property[]
  SaleContracts                              SaleContracts[]
  tenants                                    tenants?                @relation(fields: [tenantId], references: [tenantId], onDelete: Cascade, onUpdate: NoAction)
  commissions_commissions_agentIdToadmins    commissions[]           @relation("commissions_agentIdToadmins")
  commissions_commissions_approvedByToadmins commissions[]           @relation("commissions_approvedByToadmins")
  password_reset_tokens                      password_reset_tokens[]
  pdf_templates                              pdf_templates[]

  @@index([role], map: "idx_admins_role")
  @@index([tenantId], map: "idx_admins_tenant")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model has constraints using non-default deferring rules and requires additional setup for migrations. Visit https://pris.ly/d/constraint-deferring for more info.
model client_documents {
  document_id   Int                @id @default(autoincrement())
  client_id     Int
  tenant_id     Int
  document_type document_type_enum
  country       String             @default("AR") @db.VarChar(2)
  document_code String             @db.VarChar(20)
  number        String             @db.VarChar(50)
  issued_by     String?            @db.VarChar(100)
  issued_at     DateTime?          @db.Date
  expires_at    DateTime?          @db.Date
  is_primary    Boolean?           @default(false)
  is_verified   Boolean?           @default(false)
  metadata      Json?              @default("{}")
  created_at    DateTime?          @default(now()) @db.Timestamp(6)
  updated_at    DateTime?          @default(now()) @db.Timestamp(6)
  deleted_at    DateTime?          @db.Timestamp(6)
  Clients       Clients            @relation(fields: [client_id], references: [idClient], onDelete: Cascade, onUpdate: NoAction, map: "fk_client_documents_client")
  tenants       tenants            @relation(fields: [tenant_id], references: [tenantId], onDelete: Cascade, onUpdate: NoAction, map: "fk_client_documents_tenant")

  @@unique([client_id, document_type, document_code, is_primary], map: "unique_primary_doc_per_type")
  @@index([client_id], map: "idx_client_documents_client")
  @@index([country], map: "idx_client_documents_country")
  @@index([client_id, is_primary], map: "idx_client_documents_primary", where: raw("(is_primary = true)"))
  @@index([tenant_id], map: "idx_client_documents_tenant")
  @@index([document_type], map: "idx_client_documents_type")
}

model client_properties {
  idClient   Int
  propertyId Int
  role       String?    @db.VarChar(50)
  createdAt  DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime   @default(now()) @db.Timestamptz(6)
  clients    clients    @relation(fields: [idClient], references: [idClient], onDelete: Cascade, onUpdate: NoAction)
  properties properties @relation(fields: [propertyId], references: [propertyId], onDelete: Cascade, onUpdate: NoAction)

  @@id([idClient, propertyId])
}

